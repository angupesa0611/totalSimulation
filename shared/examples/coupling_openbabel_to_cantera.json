{
  "coupling": "openbabel_to_cantera",
  "label": "Molecular geometry \u2192 transport properties",
  "from": "openbabel",
  "to": "cantera",
  "steps": [
    {
      "tool": "openbabel",
      "params": {
        "simulation_type": "convert",
        "source_format": "smi",
        "source_data": "CC(=O)Oc1ccccc1C(=O)O",
        "target_format": "sdf"
      },
      "label": "Step 1: openbabel"
    },
    {
      "tool": "cantera",
      "params": {
        "simulation_type": "ignition_delay",
        "mechanism": "gri30.yaml",
        "temperature_K": 1200,
        "pressure_atm": 1,
        "composition": "H2:2,O2:1,N2:3.76",
        "end_time_s": 0.001,
        "n_points": 200
      },
      "param_map": {
        "molecule_data": "$prev.result"
      },
      "label": "Step 2: cantera"
    }
  ]
}