      "label": "Step 1: slim"
    },
    {
      "tool": "simupop",
      "params": {
        "simulation_type": "random_mating",
        "population_size": 1000,
        "n_generations": 200,
        "n_loci": 1,
        "initial_freq": 0.5
      },
      "param_map": {
        "population_size": "$prev.result.population_size"
      },
      "label": "Step 2: simupop"
    }
  ]
}