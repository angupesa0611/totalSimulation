      "tool": "slim",
      "params": {
        "simulation_type": "neutral_evolution",
        "population_size": 500,
        "n_generations": 1000,
        "mutation_rate": 1e-07,
        "recombination_rate": 1e-08,
        "sequence_length": 100000,
        "n_samples": 50
