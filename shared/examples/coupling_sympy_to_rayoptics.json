{
  "coupling": "sympy_to_rayoptics",
  "label": "Symbolic lens equation \u2192 ray trace",
  "from": "sympy",
  "to": "rayoptics",
  "steps": [
    {
      "tool": "sympy",
      "params": {
        "simulation_type": "symbolic_solve",
        "equations": [
          "x**2 - 5*x + 6"
        ],
        "solve_for": [
          "x"
        ],
        "variables": [
          "x"
        ]
      },
      "label": "Step 1: sympy"
    },
    {
      "tool": "rayoptics",
      "params": {
        "simulation_type": "singlet_lens",
        "singlet_lens": {
          "efl": 100.0,
          "f_number": 5.0,
          "wavelength": 587.56,
          "n_rays": 21,
          "r1": 90.0,
          "r2": -90.0,
          "thickness": 6.0,
          "glass": "N-BK7"
        }
      },
      "param_map": {
        "singlet_lens.efl": "$prev.result.expression"
      },
      "label": "Step 2: rayoptics"
    }
  ]
}