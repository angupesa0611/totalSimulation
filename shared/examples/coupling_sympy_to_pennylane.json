{
  "coupling": "sympy_to_pennylane",
  "label": "Symbolic Hamiltonians \u2192 parametric circuits",
  "from": "sympy",
  "to": "pennylane",
  "steps": [
    {
      "tool": "sympy",
      "params": {
        "simulation_type": "symbolic_solve",
        "equations": [
          "x**2 - 5*x + 6"
        ],
        "solve_for": [
          "x"
        ],
        "variables": [
          "x"
        ]
      },
      "label": "Step 1: sympy"
    },
    {
      "tool": "pennylane",
      "params": {
        "simulation_type": "vqe",
        "hamiltonian": [
          {
            "coeff": -0.5,
            "pauli_string": "II"
          },
          {
            "coeff": 0.5,
            "pauli_string": "ZZ"
          },
          {
            "coeff": 0.25,
            "pauli_string": "XX"
          }
        ],
        "n_qubits": 2,
        "ansatz": "basic",
        "optimizer": "gradient_descent",
        "max_iterations": 50,
        "step_size": 0.4
      },
      "param_map": {
        "hamiltonian_expr": "$prev.result.expression"
      },
      "label": "Step 2: pennylane"
    }
  ]
}