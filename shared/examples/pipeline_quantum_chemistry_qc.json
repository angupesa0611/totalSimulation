{
  "pipeline": "quantum_chemistry_qc",
  "label": "QC on Quantum Computers",
  "description": "Molecular structure \u2192 Hamiltonian \u2192 qubit mapping \u2192 variational optimization",
  "steps": [
    {
      "tool": "rdkit",
      "params": {
        "simulation_type": "descriptors",
        "smiles": "O"
      },
      "label": "Molecular structure"
    },
    {
      "tool": "pyscf",
      "params": {
        "atom_coords": "H 0 0 0; H 0 0 0.74",
        "basis": "sto-3g",
        "method": "hf",
        "charge": 0,
        "spin": 0
      },
      "label": "Hamiltonian"
    },
    {
      "tool": "qiskit",
      "params": {
        "simulation_type": "circuit_simulation",
        "n_qubits": 2,
        "gates": [
          {"name": "h", "qubits": [0]},
          {"name": "cx", "qubits": [0, 1]}
        ],
        "n_shots": 1024,
        "backend": "qasm"
      },
      "label": "VQE (Qiskit)"
    },
    {
      "tool": "pennylane",
      "params": {
        "simulation_type": "vqe",
        "hamiltonian": [
          {"coeff": -0.5, "pauli_string": "II"},
          {"coeff": 0.5, "pauli_string": "ZZ"},
          {"coeff": 0.25, "pauli_string": "XX"}
        ],
        "n_qubits": 2,
        "ansatz": "basic",
        "optimizer": "gradient_descent",
        "max_iterations": 50,
        "step_size": 0.4
      },
      "label": "Optimization (PennyLane)"
    }
  ]
}
