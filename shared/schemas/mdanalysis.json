{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MDAnalysis Parameters",
  "type": "object",
  "required": ["analysis_type"],
  "properties": {
    "analysis_type": {
      "type": "string",
      "enum": ["rmsd", "rmsf", "rg", "contacts", "ramachandran", "hbonds"],
      "default": "rmsd",
      "description": "Type of trajectory analysis to perform"
    },
    "source_job_id": {
      "type": "string",
      "description": "Job ID of a previous MD simulation to analyze"
    },
    "trajectory_data": {
      "type": "object",
      "description": "Inline trajectory data (frames, n_atoms)",
      "properties": {
        "frames": {
          "type": "array",
          "description": "Array of frames, each frame is array of [x,y,z] coordinates"
        },
        "n_atoms": {
          "type": "integer"
        }
      }
    },
    "cutoff": {
      "type": "number",
      "default": 5.0,
      "description": "Distance cutoff in Angstroms (for contacts and hbonds)"
    }
  }
}
