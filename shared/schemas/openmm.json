{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OpenMMParams",
  "type": "object",
  "required": ["pdb_content"],
  "properties": {
    "pdb_content": {
      "type": "string",
      "description": "PDB file content as string"
    },
    "forcefield": {
      "type": "array",
      "default": ["amber14-all.xml", "amber14/tip3pfb.xml"],
      "items": { "type": "string" },
      "description": "Force field XML files"
    },
    "integrator": {
      "type": "string",
      "enum": ["langevin", "verlet", "brownian"],
      "default": "langevin"
    },
    "temperature": {
      "type": "number",
      "default": 300.0,
      "description": "Temperature in Kelvin"
    },
    "friction": {
      "type": "number",
      "default": 1.0,
      "description": "Friction coefficient (1/ps) for Langevin"
    },
    "dt": {
      "type": "number",
      "default": 0.002,
      "description": "Timestep in picoseconds"
    },
    "steps": {
      "type": "integer",
      "default": 10000,
      "description": "Number of simulation steps"
    },
    "report_interval": {
      "type": "integer",
      "default": 100,
      "description": "Steps between output frames"
    },
    "minimize": {
      "type": "boolean",
      "default": true,
      "description": "Run energy minimization before simulation"
    }
  }
}
