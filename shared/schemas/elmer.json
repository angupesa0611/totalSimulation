{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ElmerParams",
  "type": "object",
  "required": ["problem_type"],
  "properties": {
    "problem_type": {
      "type": "string",
      "enum": ["structural", "thermal", "thermal_structural", "helmholtz"],
      "default": "structural"
    },
    "length_x": {
      "type": "number",
      "default": 1.0,
      "description": "Block length in x direction (m)"
    },
    "length_y": {
      "type": "number",
      "default": 0.1,
      "description": "Block height in y direction (m)"
    },
    "mesh_divisions_x": {
      "type": "integer",
      "default": 20,
      "description": "Mesh divisions in x"
    },
    "mesh_divisions_y": {
      "type": "integer",
      "default": 10,
      "description": "Mesh divisions in y"
    },
    "material": {
      "type": "object",
      "properties": {
        "youngs_modulus": { "type": "number", "default": 2e11, "description": "Young's modulus (Pa)" },
        "poisson_ratio": { "type": "number", "default": 0.3 },
        "density": { "type": "number", "default": 7800, "description": "Density (kg/m³)" },
        "conductivity": { "type": "number", "default": 50.0, "description": "Heat conductivity (W/m·K)" },
        "expansion_coeff": { "type": "number", "default": 1.2e-5, "description": "Thermal expansion coefficient (1/K)" }
      }
    },
    "loads": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["gravity", "point_force", "pressure"] },
          "value": { "type": "number" },
          "direction": { "type": "array", "items": { "type": "number" } }
        }
      }
    },
    "boundary_conditions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "boundary": { "type": "string" },
          "value": { "type": "number" }
        }
      }
    },
    "temperature_field": {
      "description": "Temperature field from previous pipeline step (accepts $prev.result.field_data)"
    }
  }
}
