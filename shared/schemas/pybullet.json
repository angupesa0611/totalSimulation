{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PyBulletParams",
  "type": "object",
  "required": ["simulation_type"],
  "properties": {
    "simulation_type": {
      "type": "string",
      "enum": ["free_fall", "collision", "pendulum", "projectile", "custom_urdf"],
      "default": "collision"
    },
    "gravity": {
      "type": "number",
      "default": -9.81,
      "description": "Gravitational acceleration (m/s²)"
    },
    "timestep": {
      "type": "number",
      "default": 0.00417,
      "description": "Physics timestep (seconds)"
    },
    "duration": {
      "type": "number",
      "default": 5.0,
      "description": "Simulation duration (seconds)"
    },
    "restitution": {
      "type": "number",
      "default": 0.9,
      "minimum": 0,
      "maximum": 1,
      "description": "Coefficient of restitution"
    },
    "friction": {
      "type": "number",
      "default": 0.5,
      "description": "Lateral friction coefficient"
    },
    "objects": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "shape": { "type": "string", "enum": ["sphere", "box", "cylinder"], "default": "sphere" },
          "mass": { "type": "number", "default": 1.0 },
          "position": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 },
          "velocity": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 },
          "orientation": { "type": "array", "items": { "type": "number" }, "minItems": 4, "maxItems": 4 },
          "radius": { "type": "number", "default": 0.5 },
          "half_extents": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 },
          "height": { "type": "number", "default": 1.0 }
        }
      }
    },
    "pendulum_length": { "type": "number", "default": 1.0 },
    "bob_mass": { "type": "number", "default": 1.0 },
    "initial_angle": { "type": "number", "default": 0.785 }
  }
}
