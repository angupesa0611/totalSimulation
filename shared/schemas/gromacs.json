{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GROMACS Parameters",
  "type": "object",
  "required": ["gro_content", "top_content", "mdp_content"],
  "properties": {
    "gro_content": {
      "type": "string",
      "description": "GROMACS coordinate file (.gro) content"
    },
    "top_content": {
      "type": "string",
      "description": "GROMACS topology file (.top) content"
    },
    "mdp_content": {
      "type": "string",
      "description": "GROMACS run parameters file (.mdp) content"
    }
  }
}
